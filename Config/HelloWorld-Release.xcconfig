// HelloWorld target — Release configuration.

PRODUCT_NAME = $(TARGET_NAME)
SWIFT_OBJC_BRIDGING_HEADER = Source/HelloWorld-Bridging-Header.h
SWIFT_VERSION = 5.0

// Target-level Release flag, parity with HELLOWORLD_DEBUG.
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) HELLOWORLD_RELEASE=1
SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(inherited) HELLOWORLD_RELEASE
